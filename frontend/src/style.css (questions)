*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{


    background:#050505;

    background-image:
    radial-gradient(circle at top,
    rgba(108,45,170,.35),
    transparent 45%),

    linear-gradient(160deg,
    #090909,
    #15091f,
    #240b38,
    #0b0b0b);

    min-height:100vh;

    color:white;

    padding:40px;
    
    position:relative;
    overflow-x:hidden;

}

.container{

    width:85%;
    max-width:1000px;

    margin:auto;

}

.exam-header{

    background:rgba(35,20,55,.95);

    border:1px solid #7f3cff;

    border-radius:15px;

    padding:25px;

    margin-bottom:35px;

    box-shadow:0 0 30px rgba(128,0,255,.25);

}

.exam-header h1{

    color:#d8b5ff;

    margin-bottom:15px;

    font-size:34px;

}

.exam-info{

    display:flex;

    justify-content:space-between;

    color:#cccccc;

    font-size:17px;

}

.question-card{

    background:rgba(25,25,25,.95);

    border-left:6px solid #9d4dff;

    border-radius:15px;

    padding:30px;

    margin-bottom:30px;

    box-shadow:0 10px 30px rgba(0,0,0,.45);
    
    position:relative;
    z-index:1;

}

.question-card h2{

    color:#be8cff;

    margin-bottom:20px;

}

.question{

    font-size:22px;

    margin-bottom:25px;

    line-height:1.5;

}

.option{

    display:block;

    padding:18px;

    margin-bottom:15px;

    border:1px solid #555;

    border-radius:10px;

    cursor:pointer;

    transition:.3s;

    background:#1b1b1b;

}

.option:hover{

    background:#39205f;

    border-color:#b25fff;

    transform:translateX(5px);

}

.option input{

    margin-right:15px;

    transform:scale(1.3);

}

.buttons{

    display:flex;

    justify-content:space-between;

    margin-top:40px;

}

button{

    border:none;

    padding:15px 35px;

    border-radius:10px;

    cursor:pointer;

    font-size:18px;

    transition:.3s;

}

.primary-btn{

    background:linear-gradient(135deg,#6d28d9,#9333ea);

    color:white;

}

.primary-btn:hover{

    background:linear-gradient(135deg,#8b5cf6,#c084fc);

    box-shadow:0 0 20px #8d5dff;

}

.secondary-btn{

    background:#303030;

    color:white;

}

.secondary-btn:hover{

    background:#444;

}


@media(max-width:768px){

.exam-info{

    flex-direction:column;

    gap:10px;

}

.buttons{

    flex-direction:column;

    gap:15px;

}

button{

    width:100%;

}

}

.container{

    position:relative;
    z-index:1;

    width:85%;
    max-width:1000px;
    margin:auto;

}


/*star 1*/

.stars{

    position:fixed;
    top:0;
    left:0;

    width:2px;
    height:2px;

    background:white;
    border-radius:50%;

    box-shadow:
        40px 80px white,
        120px 150px white,
        260px 40px white,
        380px 120px white,
        520px 70px white,
        650px 200px white,
        780px 60px white,
        910px 180px white,
        1050px 90px white,
        1180px 220px white,
        1350px 130px white,
        1500px 40px white,
        1700px 160px white,
        180px 320px white,
        420px 460px white,
        730px 520px white,
        980px 410px white,
        1220px 550px white,
        1450px 470px white,
        1680px 380px white,
        1880px 520px white;

    animation:twinkle 3s ease-in-out infinite alternate;

    z-index:0;

    pointer-events:none;

}

/*star 2*/

.stars2{

    position:fixed;
    top:0;
    left:0;

    width:1px;
    height:1px;

    background:#d9b8ff;
    border-radius:50%;

    box-shadow:
        70px 40px #d9b8ff,
        220px 110px #d9b8ff,
        310px 250px #d9b8ff,
        480px 180px #d9b8ff,
        620px 330px #d9b8ff,
        860px 70px #d9b8ff,
        980px 280px #d9b8ff,
        1140px 170px #d9b8ff,
        1380px 90px #d9b8ff,
        1520px 260px #d9b8ff,
        1710px 120px #d9b8ff,
        1900px 340px #d9b8ff;

    opacity:.7;

    animation:twinkleSlow 5s ease-in-out infinite alternate;

    z-index:0;

    pointer-events:none;

}

@keyframes twinkle{

    from{
        opacity:.3;
    }

    to{
        opacity:1;
    }

}

@keyframes twinkleSlow{

    from{
        opacity:.15;
    }

    to{
        opacity:.75;
    }

}

/*shooting star*/

.shooting-star{

    position:fixed;

    top:-100px;
    left:-300px;

    width:180px;
    height:2px;

    background:linear-gradient(
        90deg,
        rgba(255,255,255,1),
        rgba(220,180,255,.8),
        transparent
        
    );

    border-radius:50px;

    transform:rotate(-25deg);

    box-shadow:
        0 0 8px white,
        0 0 15px #d7b4ff,
        0 0 25px #b56dff;

    pointer-events:none;

    z-index:0;

    animation:shootingStar 12s linear infinite;

    opacity:0;

}

@keyframes shootingStar{

    0%{
        transform:translate(-300px,-200px) rotate(30deg);
        opacity:0;
    }

    5%{
        opacity:1;
    }

    15%{
        transform:translate(1800px,900px) rotate(30deg);
        opacity:0;
    }

    100%{
        transform:translate(1800px,900px) rotate(30deg);
        opacity:0;
    }

}
